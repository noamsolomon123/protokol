# ---------------------------------------------------------------------------
# Knesset OSINT — environment configuration.
# Copy to `.env` and adjust. NEVER commit a real `.env` (see .gitignore).
# ---------------------------------------------------------------------------

# --- Application ---
ENVIRONMENT=development
LOG_LEVEL=INFO

# --- PostgreSQL (structured data: politicians, votes, bills, statements) ---
# Local dev default points at the docker-compose `postgres` service.
DATABASE_URL=postgresql+psycopg2://osint:osint@localhost:5432/osint

# --- Neo4j (entity / corruption graph) ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change_me_neo4j
NEO4J_ENABLED=true

# --- HTTP / ingestion tuning ---
HTTP_USER_AGENT=knesset-osint/0.1 (civic transparency research)
HTTP_TIMEOUT_SECONDS=30
HTTP_MAX_RETRIES=4
ODATA_PAGE_SIZE=100

# --- Source base URLs (verified live 2026-06-20; override only if they move) ---
KNESSET_ODATA_V4_BASE=https://knesset.gov.il/OdataV4/ParliamentInfo
KNESSET_VOTES_SVC_BASE=https://knesset.gov.il/Odata/Votes.svc
OPEN_KNESSET_PIPELINES_BASE=https://production.oknesset.org/pipelines/data
KNESSET_DATA_GCS_BASE=https://storage.googleapis.com/knesset-data-pipelines/data

# --- Pilot scope ---
PILOT_PERSON_ID=965
ENABLE_OPEN_KNESSET_ENRICHMENT=true
